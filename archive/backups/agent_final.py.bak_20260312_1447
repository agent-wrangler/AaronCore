async def get_weather(query: str):
    """天气查询 - 安全异步版"""
    city = "常州"
    if "上海" in query: city = "上海"
    elif "北京" in query: city = "北京"
    elif "杭州" in query: city = "杭州"
    elif "南京" in query: city = "南京"
    elif "广州" in query: city = "广州"
    elif "深圳" in query: city = "深圳"
    
    try:
        async with aiohttp.ClientSession() as session:
            # 使用Open-Meteo API
            url = f"https://api.open-meteo.com/v1/forecast?latitude=31.81&longitude=119.97&current=temperature_2m,weather_code,wind_speed_10m&timezone=Asia/Shanghai"
            async with session.get(url, timeout=3) as resp:
                if resp.status == 200:
                    data = await resp.json()
                    current = data.get('current', {})
                    temp = current.get('temperature_2m', 'N/A')
                    weather_code = current.get('weather_code', 0)
                    wind = current.get('wind_speed_10m', 'N/A')
                    
                    # 天气代码转文字
                    weather_map = {
                        0: "☀️ 晴", 1: "🌤️ 少云", 2: "⛅ 局部多云",
                        3: "☁️ 多云", 45: "🌫️ 雾", 48: "🌫️ 冻雾",
                        51: "🌦️ 小雨", 53: "🌧️ 中雨", 55: "🌧️ 大雨",
                        61: "🌧️ 小雨", 63: "🌧️ 中雨", 65: "🌧️ 大雨",
                        71: "🌨️ 小雪", 73: "🌨️ 中雪", 75: "🌨️ 大雪",
                        80: "🌦️ 阵雨", 81: "🌧️ 强阵雨", 82: "⛈️ 暴雨",
                        85: "🌨️ 阵雪", 86: "🌨️ 强阵雪", 95: "⛈️ 雷暴",
                        96: "⛈️ 雷暴伴有冰雹", 99: "⛈️ 强雷暴伴有冰雹"
                    }
                    weather = weather_map.get(weather_code, "🌤️ 未知")
                    
                    stats_data["output_tokens"] += 100
                    return f"""🌤️ **{city}天气报告**
━━━━━━━━━━━━━━━━
📍 城市：{city}
🌡️ 温度：{temp}°C
🌤️ 天气：{weather}
💨 风速：{wind} km/h
🕐 更新时间：{datetime.now().strftime('%H:%M')}

💡 数据来源：Open-Meteo API"""
    except Exception as e:
        stats_data["output_tokens"] += 80
        return f"""🌤️ **{city}天气查询**
━━━━━━━━━━━━━━━━
📍 城市：{city}
⚠️ 状态：API查询失败
💡 建议：请检查网络连接或稍后重试

错误信息：{str(e)[:50]}"""

