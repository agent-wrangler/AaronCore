<!DOCTYPE html>
<html><head><meta charset="UTF-8"><title>Nova</title>
<style>
*{margin:0;padding:0;box-sizing:border-box;user-select:text}
::-webkit-scrollbar{width:6px}
::-webkit-scrollbar-track{background:#1a1a2a}
::-webkit-scrollbar-thumb{background:#3a3a5a;border-radius:3px}
::-webkit-scrollbar-thumb:hover{background:#4a4a6a}
/* 亮色主题 */
body.light{background:#f5f5f5;color:#1a1a1a}
body.light .sidebar{background:#fff;box-shadow:2px 0 10px rgba(0,0,0,0.1)}
body.light .menu{color:#333}
body.light .menu:hover{background:#eee}
body.light .menu.active{background:#e0e7ff;color:#4f46e5}
body.light .chat{background:#fff}
body.light .bubble{background:#e5e7eb;color:#1a1a1a}
body.light .msg.user .bubble{background:#4f46e5;color:#fff}
body.light .input{background:#fff;border-top:1px solid #e5e7eb}
body.light .input textarea{background:#f9fafb;color:#1a1a1a;border:1px solid #d1d5db}
body.light::-webkit-scrollbar-track{background:#f1f1f1}
body.light::-webkit-scrollbar-thumb{background:#ccc}
body.light::-webkit-scrollbar-thumb:hover{background:#aaa}
body{font-family:'Segoe UI',system-ui,-apple-system,sans-serif;background:#0f0f1a;color:#e2e8f0;height:100vh;overflow:hidden;display:flex}
.sidebar{width:240px;background:#1a1a2a;display:flex;flex-direction:column;padding:20px 0;border-right:1px solid #2a2a3a}
.logo{font-size:24px;font-weight:700;color:#8b5cf6;padding:0 20px 20px;display:flex;align-items:center;gap:10px}
.logo:before{content:'✨'}
.menu{display:flex;align-items:center;gap:12px;padding:12px 20px;color:#94a3b8;cursor:pointer;transition:all 0.2s;font-size:15px;border-left:3px solid transparent}
.menu:hover{background:rgba(139,92,246,0.1);color:#c4b5fd}
.menu.active{background:rgba(139,92,246,0.2);color:#8b5cf6;border-left-color:#8b5cf6}
.menu:before{font-size:18px}
#m1:before{content:'💬'}
#m2:before{content:'⚡'}
#m3:before{content:'📊'}
#m4:before{content:'⚙️'}
.main{flex:1;display:flex;flex-direction:column}
.header{height:60px;background:rgba(26,26,42,0.8);backdrop-filter:blur(10px);border-bottom:1px solid #2a2a3a;display:flex;align-items:center;justify-content:space-between;padding:0 24px}
.header-title{font-size:18px;font-weight:600}
.header-actions{display:flex;gap:12px;align-items:center}
.header-btn{padding:8px 16px;background:rgba(139,92,246,0.2);color:#8b5cf6;border:none;border-radius:8px;cursor:pointer;font-size:14px;transition:all 0.2s}
.header-btn:hover{background:rgba(139,92,246,0.3)}
.content{flex:1;overflow:hidden;position:relative}
.chat{height:100%;overflow-y:auto;padding:24px;display:flex;flex-direction:column;gap:16px}
.msg{display:flex;flex-direction:column;max-width:80%}
.msg.user{align-self:flex-end}
.msg.user .bubble{background:#8b5cf6;color:#fff;border-radius:18px 18px 4px 18px}
.msg .meta{font-size:12px;color:#94a3b8;margin-bottom:4px;display:flex;align-items:center;gap:6px}
.msg .bubble{padding:12px 16px;background:rgba(42,58,90,0.5);border-radius:18px 18px 18px 4px;line-height:1.5;word-break:break-word}
.thinking{display:inline-flex;gap:4px;margin-left:8px}
.thinking span{width:4px;height:4px;background:#94a3b8;border-radius:50%;animation:pulse 1.4s infinite}
.thinking span:nth-child(2){animation-delay:0.2s}
.thinking span:nth-child(3){animation-delay:0.4s}
@keyframes pulse{0%,100%{opacity:0.4}50%{opacity:1}}
.input{background:rgba(26,26,42,0.8);backdrop-filter:blur(10px);border-top:1px solid #2a2a3a;padding:16px 24px}
.input-container{display:flex;gap:12px;align-items:flex-end}
.input textarea{flex:1;background:rgba(42,58,90,0.3);border:none;border-radius:12px;padding:14px 16px;color:#e2e8f0;font-size:15px;resize:none;min-height:56px;max-height:120px;font-family:inherit;transition:all 0.2s}
.input textarea:focus{outline:none;background:rgba(42,58,90,0.5);box-shadow:0 0 0 2px rgba(139,92,246,0.3)}
.input textarea::placeholder{color:#64748b}
.input-buttons{display:flex;gap:8px;flex-shrink:0}
.input-btn{padding:12px 16px;background:rgba(139,92,246,0.2);color:#8b5cf6;border:none;border-radius:10px;cursor:pointer;font-size:14px;font-weight:500;transition:all 0.2s;display:flex;align-items:center;gap:6px;min-width:44px;justify-content:center}
.input-btn:hover{background:rgba(139,92,246,0.3);transform:translateY(-1px)}
.input-btn:active{transform:translateY(0)}
.input-btn.primary{background:#8b5cf6;color:#fff}
.input-btn.primary:hover{background:#7c3aed}
.input-btn.secondary{background:rgba(42,58,90,0.5);color:#94a3b8}
.input-btn.secondary:hover{background:rgba(42,58,90,0.7);color:#e2e8f0}
.input-btn.danger{background:rgba(239,68,68,0.2);color:#f87171}
.input-btn.danger:hover{background:rgba(239,68,68,0.3)}
.input-btn:disabled{opacity:0.5;cursor:not-allowed;transform:none}
.input-actions{display:flex;justify-content:space-between;align-items:center;margin-top:12px;font-size:13px;color:#64748b}
.input-hint{font-size:12px;color:#64748b}
.input-hint kbd{background:rgba(42,58,90,0.5);padding:2px 6px;border-radius:4px;font-family:monospace;font-size:11px;margin:0 2px}
</style>
</head>
<body class="dark">
<div class="sidebar">
 <div class="logo">NovaCore</div>
 <div class="menu active" id="m1" onclick="show(1)">对话</div>
 <div class="menu" id="m2" onclick="show(2)">技能矩阵</div>
 <div class="menu" id="m3" onclick="show(3)">数据看板</div>
 <div class="menu" id="m4" onclick="show(4)">设置</div>
 <div style="margin-top:auto;padding:20px;font-size:12px;color:#64748b;text-align:center">
  <div>端口: 8090</div>
  <div>模型: MiniMax-M2.5</div>
  <div>状态: <span id="statusText">运行中</span></div>
 </div>
</div>
<div class="main">
 <div class="header">
  <div class="header-title" id="pageTitle">与 Nova 对话</div>
  <div class="header-actions">
   <button class="header-btn" onclick="toggleTheme()" id="headerThemeBtn">🌙</button>
   <button class="header-btn" onclick="location.reload()">🔄 刷新</button>
   <button class="header-btn" onclick="exportChat()">📥 导出</button>
  </div>
 </div>
 <div class="content">
  <div class="chat" id="chat"></div>
 </div>
 <div class="input">
  <div class="input-container">
   <textarea id="inp" placeholder="输入消息..." onkeydown="if(event.keyCode==13&&!event.shiftKey){event.preventDefault();send();}"></textarea>
   <div class="input-buttons">
    <button class="input-btn secondary" onclick="clearChat()" title="清空对话">
     🗑️
    </button>
    <button class="input-btn secondary" onclick="toggleVoice()" id="voiceBtn" title="语音输入">
     🎤
    </button>
    <button class="input-btn primary" onclick="send()" id="sendBtn" title="发送消息 (Enter)">
     📤 发送
    </button>
   </div>
  </div>
  <div class="input-actions">
   <div class="input-hint">
    <kbd>Enter</kbd> 发送 • <kbd>Shift+Enter</kbd> 换行 • <kbd>Ctrl+Z</kbd> 撤销
   </div>
   <div class="input-hint" id="charCount">0/2000</div>
  </div>
 </div>
</div>
<script>
var chatHistory='';
var voiceEnabled=false;
function T(){var d=new Date();return d.getHours().toString().padStart(2,'0')+':'+d.getMinutes().toString().padStart(2,'0');}
function updateCharCount(){
 var inp=document.getElementById('inp');
 var count=inp.value.length;
 document.getElementById('charCount').textContent=count+'/2000';
 document.getElementById('sendBtn').disabled=count===0;
}
function clearChat(){
 if(confirm('确定要清空当前对话吗？')) {
  chatHistory='';
  document.getElementById('chat').innerHTML='';
  localStorage.removeItem('nova_chat_history');
  addMessage('系统','对话已清空','system');
 }
}
function toggleVoice(){
 voiceEnabled=!voiceEnabled;
 var btn=document.getElementById('voiceBtn');
 if(voiceEnabled){
  btn.classList.remove('secondary');
  btn.classList.add('primary');
  btn.title='语音输入已开启 (点击关闭)';
  btn.innerHTML='🎤 开启';
  alert('语音输入功能需要浏览器权限，请在设置中启用麦克风。');
 }else{
  btn.classList.remove('primary');
  btn.classList.add('secondary');
  btn.title='语音输入';
  btn.innerHTML='🎤';
 }
}
function addMessage(sender,text,type){
 var chat=document.getElementById('chat');
 var msgDiv=document.createElement('div');
 msgDiv.className='msg '+(type==='user'?'user':'assistant');
 var meta=document.createElement('div');
 meta.className='meta';
 meta.innerHTML='<span>'+sender+'</span> • <span>'+T()+'</span>';
 var bubble=document.createElement('div');
 bubble.className='bubble';
 bubble.textContent=text;
 msgDiv.appendChild(meta);
 msgDiv.appendChild(bubble);
 chat.appendChild(msgDiv);
 chat.scrollTop=chat.scrollHeight;
 if(type==='user'||type==='assistant'){
  chatHistory+=msgDiv.outerHTML;
  localStorage.setItem('nova_chat_history',chatHistory);
 }
}
function send(){
 var inp=document.getElementById('inp');
 var text=inp.value.trim();
 if(text==='')return;
 addMessage('你',text,'user');
 inp.value='';
 updateCharCount();
 document.getElementById('sendBtn').disabled=true;
 var thinkingDiv=document.createElement('div');
 thinkingDiv.className='msg assistant';
 var meta=document.createElement('div');
 meta.className='meta';
 meta.innerHTML='<span>Nova</span> • <span>思考中</span><div class="thinking"><span></span><span></span><span></span></div>';
 var bubble=document.createElement('div');
 bubble.className='bubble';
 bubble.textContent='正在思考...';
 thinkingDiv.appendChild(meta);
 thinkingDiv.appendChild(bubble);
 document.getElementById('chat').appendChild(thinkingDiv);
 document.getElementById('chat').scrollTop=document.getElementById('chat').scrollHeight;
 setTimeout(function(){
  thinkingDiv.remove();
  addMessage('Nova','这是一个模拟回复。实际应该连接到后端API。','assistant');
  document.getElementById('sendBtn').disabled=false;
 },1500);
}
function toggleTheme(){
 var body=document.body;
 var btn=document.getElementById('headerThemeBtn');
 if(body.classList.contains('dark')){
  body.classList.remove('dark');
  body.classList.add('light');
  btn.textContent='☀️';
  btn.title='切换到暗色主题';
  localStorage.setItem('nova_theme','light');
 }else{
  body.classList.remove('light');
  body.classList.add('dark');
  btn.textContent='🌙';
  btn.title='切换到亮色主题';
  localStorage.setItem('nova_theme','dark');
 }
}
function exportChat(){
 var content='=== NovaCore 对话导出 ===\n时间：'+new Date().toLocaleString()+'\n\n';
 var messages=document.querySelectorAll('.msg');
 messages.forEach(function(msg){
  var sender=msg.querySelector('.meta span:first-child').textContent;
  var time=msg.querySelector('.meta span:last-child').textContent;
  var text=msg.querySelector('.bubble').textContent;
  content+='['+time+'] '+sender+'：'+text+'\n';
 });
 var blob=new Blob([content],{type:'text/plain;charset=utf-8'});
 var url=URL.createObjectURL(blob);
 var a=document.createElement('a');
 a.href=url;
 a.download='nova_chat_'+new Date().getTime()+'.txt';
 a.click();
 URL.revokeObjectURL(url);
 alert('对话已导出为文本文件！');
}
window.onload=function(){
 var savedTheme=localStorage.getItem('nova_theme');
 if(savedTheme==='light'){
  document.body.classList.remove('dark');
  document.body.classList.add('light');
  document.getElementById('headerThemeBtn').textContent='☀️';
  document.getElementById('headerThemeBtn').title='切换到暗色主题';
 }
 var saved=localStorage.getItem('nova_chat_history');
 if(saved){
  chatHistory=saved;
  document.getElementById('chat').innerHTML=saved;
  document.getElementById('chat').scrollTop=chat.scrollHeight;
 }
 var inp=document.getElementById('inp');
 inp.addEventListener('input',updateCharCount);
 updateCharCount();
 if(!saved||saved.trim()===''){
  addMessage('Nova','你好！我是 Nova，你的智能助手。有什么可以帮你的吗？','assistant');
 }
};
function show(n){
 for(var i=1;i<=4;i++)document.getElementById('m'+i).classList.remove('active');
 document.getElementById('m'+n).classList.add('active');
 if(n==1){
  document.getElementById('chat').innerHTML=chatHistory;
  document.getElementById('chat').scrollTop=document.getElementById('chat').scrollHeight;
 }
 if(n==2){
  document.getElementById('chat').innerHTML='<div style="padding:20px;"><h2>⚡ 技能矩阵</h2><div>技能页面（模拟数据）</div></div>';
 }
 if(n==3){
  document.getElementById('chat').innerHTML='<div style="padding:20px;"><h2>📊 数据看板</h2><div>数据页面（模拟数据）</div></div>';
 }
 if(n==4){
  document.getElementById('chat').innerHTML='<div style="padding:20px;"><h2>⚙️ 设置</h2><div>设置页面（模拟数据）</div></div>';
 }
}
</script>
</body>
</html>