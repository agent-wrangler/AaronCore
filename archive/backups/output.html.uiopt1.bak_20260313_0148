 if(layer==='L8') return '能力进化';
 return '系统事件';
}

function memoryEventCopy(e){
 var layer=e.layer||'Lx';
 var content=e.content||'';
 var type=e.event_type||'';
 var skill=detectSkillName(content);
 var displayTitle='';
 var cleaned='';

 if(isDirtyText(content)){
  if(layer==='L5') cleaned = skill ? '掌握了新技能：'+'「'+skill+'」'+'（能力边界又往外长了一点）' : '掌握了一项新的技能能力，技能矩阵正在继续扩展。';
  else if(layer==='L6') cleaned = skill ? '使用了：'+'「'+skill+'」'+'（这项能力正在变得越来越熟练）' : '完成了一次技能调用，执行痕迹已经被记录下来。';
  else if(layer==='L8') cleaned = skill ? '习得经验：'+'「'+skill+'」'+'（将转化为后续优化依据）' : '习得了一条新的成长经验，它会继续影响后续优化方向。';
  else if(layer==='L3') cleaned = '生成了一枚新的记忆结晶，这段内容已经开始形成稳定结构。';
  else if(layer==='L1') cleaned = '捕捉到一枚新的记忆粒子，已经进入感知层等待沉淀。';
  else if(layer==='L4') cleaned = '人格表达层发生了一次细微调整，后续回复会更贴近当前的陪伴感。';
  else if(layer==='L7') cleaned = '收到一条新的反馈，这次修正会继续影响后续判断。';
  else cleaned = '记录了一次新的系统变化。';
 } else {
  cleaned = content || type || '记录了一次系统变化';
 }

 displayTitle = layerLabel(layer);
 return { title: displayTitle, content: emphasizeQuoted(cleaned) };
}

