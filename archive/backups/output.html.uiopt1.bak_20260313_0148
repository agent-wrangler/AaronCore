function emphasizeQuoted(text){
 text=String(text||'');
 text=text.replace(/<strong[^>]*>「([^」]+)」<\/strong>/g,'「$1」');
 text=text.replace(/(解锁新技能：|掌握了新技能：|使用了：|习得经验：)\s*「?([a-zA-Z_][a-zA-Z0-9_-]*)」?/g,'$1<strong style="font-weight:700;letter-spacing:0.2px;">「$2」</strong>');
 text=text.replace(/学会了\s*「?([a-zA-Z_][a-zA-Z0-9_-]*)」?\s*技能/g,'学会了 <strong style="font-weight:700;letter-spacing:0.2px;">「$1」</strong> 技能');
 text=text.replace(/「([^」]+)」/g,'<strong style="font-weight:700;letter-spacing:0.2px;">「$1」</strong>');
 text=text.replace(/(^|[^「>])(story|weather|draw|run_code|llm_chat|web_search)(?![a-zA-Z0-9_-]|[^<]*<\/strong>|」)/g,'$1<strong style="font-weight:700;letter-spacing:0.2px;">「$2」</strong>');
 return text;
}

function detectSkillName(text){
 text=String(text||'');
 var m=text.match(/(story|weather|draw|run_code|llm_chat|web_search)/i);
 return m?m[1]:'';
}

function isDirtyText(text){
 text=String(text||'');
 return /\?\?\?|␀|||��|\?o|\?��/.test(text);
}

function layerLabel(layer){
