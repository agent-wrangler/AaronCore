"""
NovaCore Desktop - 桌面客户端
"""
import webview
import threading
import time
import requests
import sys
import os
import ctypes

# 先启动后端服务
def start_backend():
    import subprocess
    os.chdir(r"C:\Users\36459\NovaCore")
    subprocess.Popen([r"C:\Program Files\Python311\python.exe", "agent.py"])

# 获取屏幕尺寸
user32 = ctypes.windll.user32
screen_width = user32.GetSystemMetrics(0)
screen_height = user32.GetSystemMetrics(1)

# 计算居中位置
window_width = 1100
window_height = 800
x = (screen_width - window_width) // 2
y = (screen_height - window_height) // 2

# 启动后端
start_backend()
time.sleep(3)  # 等待服务启动

# 创建桌面窗口（居中）
webview.create_window(
    'NovaCore', 
    'http://localhost:8090/',
    width=window_width,
    height=window_height,
    x=x,
    y=y,
    resizable=True
)

print("NovaCore 启动中...")
webview.start()
