{
  "name": "aaroncore-desktop-runtime-35",
  "version": "1.0.0",
  "private": true,
  "description": "Desktop packaging wrapper for AaronCore",
  "author": "AaronCore",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "pack": "set CSC_IDENTITY_AUTO_DISCOVERY=false&& electron-builder --dir",
    "dist:portable": "set CSC_IDENTITY_AUTO_DISCOVERY=false&& electron-builder --win portable",
    "dist:nsis": "set CSC_IDENTITY_AUTO_DISCOVERY=false&& electron-builder --win nsis"
  },
  "devDependencies": {
    "electron": "35.7.5",
    "electron-builder": "^26.0.12"
  },
  "build": {
    "appId": "com.aaroncore.desktop",
    "productName": "AaronCore",
    "icon": "../static/icon/aaroncore.ico",
    "asar": true,
    "npmRebuild": false,
    "files": [
      "main.js",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "../agent_final.py",
        "to": "aaroncore/agent_final.py"
      },
      {
        "from": "../output.html",
        "to": "aaroncore/output.html"
      },
      {
        "from": "../brain",
        "to": "aaroncore/brain"
      },
      {
        "from": "../configs",
        "to": "aaroncore/configs"
      },
      {
        "from": "../core",
        "to": "aaroncore/core"
      },
      {
        "from": "../routes",
        "to": "aaroncore/routes"
      },
      {
        "from": "../shell",
        "to": "aaroncore/shell",
        "filter": [
          "**/*",
          "!node_modules{,/**}"
        ]
      },
      {
        "from": "../skills",
        "to": "aaroncore/skills"
      },
      {
        "from": "../static",
        "to": "aaroncore/static"
      },
      {
        "from": "../tools",
        "to": "aaroncore/tools"
      },
      {
        "from": "../memory/.gitkeep",
        "to": "aaroncore/memory/.gitkeep"
      },
      {
        "from": "../state_data/.gitkeep",
        "to": "aaroncore/state_data/.gitkeep"
      }
    ],
    "directories": {
      "output": "../../AaronCoreDesktop"
    },
    "win": {
      "icon": "../static/icon/aaroncore.ico",
      "signAndEditExecutable": false,
      "verifyUpdateCodeSignature": false,
      "target": [
        "portable",
        "nsis"
      ]
    }
  }
}
